  <property name="styleSheet">
   <string notr="true">QMainWindow {
	background-color: rgb(222, 221, 218);
}

/* ************************************************************ */

QGroupBox {
    border: 2px solid #bdc3c7;
    border-radius: 12px;
    margin-top: 12px;
    padding: 20px 10px 10px 10px;
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #ffffff, stop: 1 #ecf0f1);
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 20px;
    padding: 5px 15px;
    background-color: #3498db;
    color: white;
    border-radius: 8px;
    font-size: 13px;
}

/* ************************************************************ */

QLineEdit {
    border: 2px solid #ddd;
    border-radius: 12px;
    padding: 10px 15px 10px 40px;
    background-color: #f5f5f5;
    font-size: 14px;
    color: #2c3e50; 
}

QLineEdit:focus {
    border: 2px solid #3498db;
    background-color: white;
    padding: 9px 14px 9px 39px;
    color: #2c3e50; 
}

QLineEdit:hover {
    border: 2px solid #3498db;
    color: #2c3e50;
}

QLineEdit::placeholder {
    color: #95a5a6;
    font-style: italic;
}

/* ************************************************************ */

QCheckBox {
    spacing: 8px;
    font-size: 13px;
    color: #2c3e50;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #bdc3c7;
    border-radius: 4px;
    background-color: white;
}

QCheckBox::indicator:checked {
    background-color: #3498db;
    border-color: #3498db;
    image: url(checkmark.png);
}

QCheckBox::indicator:hover {
    border-color: #3498db;
}

QCheckBox::indicator:checked:hover {
    background-color: #2980b9;
    border-color: #2980b9;
}

QCheckBox::indicator:checked {
    background-color: #3498db;
    border-color: #3498db;
}

/* ************************************************************ */

QTextBrowser {
    border: 2px solid #ddd;
    border-radius: 12px;
    padding: 15px;
    background-color: #f5f5f5;
    font-size: 13px;
    color: #2c3e50;
    selection-background-color: #3498db;
    selection-color: white;
}

QTextBrowser:focus {
    border: 2px solid #3498db;
    background-color: white;
    padding: 14px;
}

QTextBrowser:hover {
    border: 2px solid #3498db;
}

QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 10px;
    margin: 0;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #bdc3c7;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #3498db;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: none;
    background: transparent;
    height: 10px;
    margin: 0;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background: #bdc3c7;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #3498db;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}

/* ************************************************************ */

QPushButton {
    border: 2px solid #3498db;
    border-radius: 10px;
    padding: 10px 20px;
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #3498db, stop: 1 #2980b9);
    color: white;
    font-size: 13px;
    font-weight: bold;
    min-width: 80px;
}

QPushButton:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #2980b9, stop: 1 #2471a3);
    border-color: #2980b9;
}

QPushButton:pressed {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #2471a3, stop: 1 #1a5276);
    border-color: #2471a3;
    padding-top: 12px;
    padding-bottom: 8px;
}

QPushButton:focus {
    border: 2px solid #1a5276;
    padding: 9px 19px;
}

QPushButton:disabled {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #bdc3c7, stop: 1 #95a5a6);
    border-color: #95a5a6;
    color: #ecf0f1;
}</string>
